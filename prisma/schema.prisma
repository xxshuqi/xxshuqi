generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Photo {
  id          String   @id @default(cuid())
  filename    String
  originalUrl String
  thumbUrl    String
  width       Int
  height      Int
  blurhash    String?
  caption     String?
  category    String?
  camera      String?
  lens        String?
  aperture    String?
  shutter     String?
  iso         String?
  filmSim     String?
  featured    Boolean  @default(false)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  journalEntry   JournalEntry? @relation(fields: [journalEntryId], references: [id])
  journalEntryId String?

  likes    Like[]
  comments Comment[]
}

model Like {
  id        String   @id @default(cuid())
  photoId   String
  photo     Photo    @relation(fields: [photoId], references: [id], onDelete: Cascade)
  sessionId String
  createdAt DateTime @default(now())

  @@unique([photoId, sessionId])
}

model Comment {
  id        String   @id @default(cuid())
  photoId   String
  photo     Photo    @relation(fields: [photoId], references: [id], onDelete: Cascade)
  author    String
  body      String
  createdAt DateTime @default(now())
}

model JournalEntry {
  id           String   @id @default(cuid())
  title        String
  subtitle     String?
  slug         String   @unique
  body         String
  category     String?
  published    Boolean  @default(false)
  coverPhotoId String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  photos Photo[]
}
